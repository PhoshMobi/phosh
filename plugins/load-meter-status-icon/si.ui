<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.24"/>
  <template class="PhoshLoadMeterStatusIcon" parent="PhoshStatusIcon">
    <property name="visible">1</property>
    <property name="extra-widget">graph</property>
    <property name="pixel-size">0</property>
    <property name="priority">5</property>
  </template>
  <object class="GtkDrawingArea" id="graph">
    <property name="height-request">18</property>
    <property name="width-request">18</property>
    <property name="visible">1</property>
    <signal name="draw" handler="on_draw" swapped="false"/>
  </object>
</interface>
